# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_flow
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_flow

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# AI Rate Limit (per minute per user)
AI_RATE_LIMIT=10
